# Google Auth
Authentication__Google__ClientId=your-google-client-id
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Allowed users (add more with __2, __3, etc.)
AllowedUsers__0=you@gmail.com
AllowedUsers__1=

# Gemini
Gemini__ApiKey=your-gemini-api-key
Gemini__Model=gemini-2.5-pro

# Backfill: regenerate Transcribed_With_Notes.md for Finished jobs created before that feature.
# Bounded per worker run. Set Enabled=false or MaxJobsPerRun=0 to disable.
Backfill__Enabled=true
Backfill__MaxJobsPerRun=5

# App port
APP_PORT=3000
